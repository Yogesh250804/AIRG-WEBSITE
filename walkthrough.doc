<head>
    <title>Design and Development Revisions Walkthrough</title>
    <style>
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            line-height: 1.6;
            color: #333333;
            margin: 40px;
        }
        h1 {
            color: #EB0028;
            border-bottom: 2px solid #EB0028;
            padding-bottom: 10px;
            font-size: 24pt;
        }
        h2 {
            color: #1a1a2e;
            font-size: 16pt;
            margin-top: 30px;
            border-bottom: 1px solid #e0e0e0;
            padding-bottom: 5px;
        }
